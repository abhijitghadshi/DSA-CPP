#include<iostream>
using namespace std;
int partition (int arr[],int st,int end){
    int idx=st-1; int pivot=arr[end];
    for(int i=st;i<end;i++){
        if(arr[i]<=pivot){
            idx++;
            swap(arr[i],arr[idx]);
        }
    }
    idx++;
    swap(arr[idx],arr[end]);
    return idx;
}
void qsort(int arr[], int st, int end) {
        if(st<end){
        int pivotidx = partition(arr,st,end);
        qsort(arr,st,pivotidx-1);
        qsort(arr,pivotidx+1,end);
    }
}
int main(){
    int arr[]={5,4,3,2,1};
    int n =5;
    qsort(arr,0,n-1);
    for(int i=0;i<n;i++){
        cout<<arr[i]<<" ";
    }
}
