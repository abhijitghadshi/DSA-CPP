#include<iostream>
using namespace std;

void sort(int arr[],int n){
    for(int i=0;i<n-1;i++){
        int small = i;
        for(int j=i+1;j<n;j++){
            if(arr[j]<arr[small]){
                small=j;
            }
        }
        swap(arr[i],arr[small]);
    }
}

void display(int arr[],int n){
    for(int i=0;i<n;i++){
        cout<<arr[i]<<" ";
    }
}

int main(){
    int arr[]={5,4,3,2,1};
    int n= sizeof(arr)/sizeof(arr[0]);
    sort(arr,n);
    display(arr,n);
}
