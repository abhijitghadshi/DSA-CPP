#include<iostream>
#include<queue>
#include<vector>
using namespace std;

int V=5;
vector<vector<int>>adj(V);

void add_edges(int v,int u){
    adj[v].push_back(u);
    adj[u].push_back(v);
}

void BFS(int start){
    queue <int> q;
    vector<bool>vis(V,false);
    q.push(start);
    vis[start]=true;

    while(q.size()>0){
        int u = q.front();
        q.pop();
        cout<<u<<" ";
        
        for(int v : adj[u]){
        if(! vis[v]){
            vis[v]= true;
            q.push(v);
                         }
        }
    }
}
int main(){
    add_edges(0,1);
    add_edges(0,2);
    add_edges(1,3);
    add_edges(2,4);

    cout << "BFS: ";
    BFS(0);

    return 0;
}

