#include<iostream>
#include<queue>
#include<vector>
using namespace std;

int V=5;
vector<vector<int>>adj(V);

void addedges(int u,int v){
    adj[v].push_back(u);
    adj[u].push_back(v);
}

void DFS_helper(int u,vector<bool> vis){
    cout<<u<<" ";
    vis[u]=true;
    for (int v : adj[u]){
        if(! vis[v]){
            DFS_helper(v,vis);
        }
    }
}
void DFS(){
    int src=0;
    vector<bool>vis(V,false);
    DFS_helper(src,vis);

}
int main(){
    addedges(0,1);
    addedges(0,2);
    addedges(1,3);
    addedges(2,4);

    cout << "DFS: ";
    DFS();

    return 0;

    
}
